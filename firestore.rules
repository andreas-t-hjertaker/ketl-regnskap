rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Hjelpefunksjoner ───────────────────────────────────────────────────────

    function erAutentisert() {
      return request.auth != null;
    }

    function erEier(uid) {
      return erAutentisert() && request.auth.uid == uid;
    }

    function erAdmin() {
      return erAutentisert() && request.auth.token.admin == true;
    }

    // ─── Webhooks ────────────────────────────────────────────────────────────────
    match /webhooks/{webhookId} {
      allow read: if erAutentisert() && resource.data.userId == request.auth.uid;
      allow create: if erAutentisert() && request.resource.data.userId == request.auth.uid
        && request.resource.data.url is string
        && request.resource.data.hendelser is list;
      allow update, delete: if erAutentisert() && resource.data.userId == request.auth.uid;
    }

    match /webhook_logg/{loggId} {
      allow read: if erAutentisert() && resource.data.userId == request.auth.uid;
      allow write: if erAdmin(); // Kun Cloud Functions skriver
    }

    // ─── Abonnementer ────────────────────────────────────────────────────────────
    match /subscriptions/{uid} {
      allow read: if erEier(uid);
      allow write: if erAdmin(); // Kun Cloud Functions (admin SDK) skriver
    }

    // ─── API-nøkler ──────────────────────────────────────────────────────────────
    match /apiKeys/{keyId} {
      allow read: if erAutentisert() && resource.data.userId == request.auth.uid;
      allow write: if erAdmin();
    }

    // ─── Feature flags (offentlig lesing) ───────────────────────────────────────
    match /featureFlags/{flagId} {
      allow read: if true;
      allow write: if erAdmin();
    }

    // ─── Notater ─────────────────────────────────────────────────────────────────
    match /notes/{noteId} {
      allow read: if erAutentisert() && resource.data.userId == request.auth.uid;
      allow create: if erAutentisert() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if erAutentisert() && resource.data.userId == request.auth.uid;
    }

    // ─── Brukerdata (isolert per bruker) ────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if erEier(uid);

      // Klienter
      match /klienter/{klientId} {
        allow read, write: if erEier(uid);
      }

      // Bilag og posteringer
      match /bilag/{bilagId} {
        allow read: if erEier(uid);
        allow create: if erEier(uid) && (
          !request.resource.data.keys().hasAny(['klientId']) ||
          request.resource.data.klientId is string
        );
        allow update: if erEier(uid) && (
          !request.resource.data.keys().hasAny(['klientId']) ||
          request.resource.data.klientId is string
        );
        // Bokføringsloven § 9 + § 13: bokførte og krediterte bilag kan ikke slettes
        // i oppbevaringsperioden (5 år). Kun "ubehandlet", "foreslått", "avvist" og
        // "arkivert" (utløpt oppbevaringsplikt, merket av Cloud Function) kan slettes.
        // "foreslått" er ikke bokført — AI-forslag ennå ikke godkjent av bruker.
        allow delete: if erEier(uid) &&
          resource.data.status in ["ubehandlet", "foreslått", "avvist", "arkivert"];
      }

      // Revisjonslogg — kun lesing for bruker, Cloud Functions kan skrive
      match /audit_log/{logId} {
        allow read: if erEier(uid);
        allow create: if erEier(uid); // Klient skriver via audit.ts
        allow update, delete: if false; // Immutable
      }

      // Kontoplan (bruker-tilpasset)
      match /kontoplan/{kontoId} {
        allow read, write: if erEier(uid);
      }

      // Bilagsnummer-tellere — atomisk inkrement via transaksjon
      match /counters/{counterId} {
        allow read, write: if erEier(uid);
      }

      // Motparter (kunder og leverandører) — SAF-T-krav
      match /motparter/{motpartId} {
        allow read: if erEier(uid);
        allow create: if erEier(uid) &&
          request.resource.data.type in ["kunde", "leverandor"] &&
          request.resource.data.navn is string &&
          request.resource.data.klientId is string;
        allow update: if erEier(uid);
        allow delete: if erEier(uid);
      }
    }
  }
}
